{
  "name": "@seshuk/rspress-plugin-scalar",
  "version": "0.1.1",
  "description": "Rspress plugin to render Scalar API Reference from an OpenAPI spec",
  "keywords": [
    "api-reference",
    "openapi",
    "rspress",
    "rspress-plugin",
    "scalar",
    "swagger"
  ],
  "homepage": "https://github.com/maximseshuk/rspress-plugin-scalar#readme",
  "bugs": {
    "url": "https://github.com/maximseshuk/rspress-plugin-scalar/issues"
  },
  "license": "MIT",
  "author": "Maxim Seshuk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maximseshuk/rspress-plugin-scalar.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build -w",
    "clean": "rm -rf dist",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@scalar/types": "^0.11.0"
  },
  "devDependencies": {
    "@rsbuild/plugin-react": "^2.0.0",
    "@rslib/core": "^0.21.5",
    "@rspress/core": "^2.0.11",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "react": "^19.2.6",
    "rsbuild-plugin-publint": "^0.3.4",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@rspress/core": "^2.0.0-rc.4 || ^2.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.1.1",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^20.19.0 || >=22.18.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
